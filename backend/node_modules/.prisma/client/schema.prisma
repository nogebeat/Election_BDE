datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  votes     Vote[]
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, code])
}

model Vote {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  listName      String
  day           Int
  scoreBouffe   Int
  scoreAmbiance Int
  scoreProjets  Int
  scoreRespect  Int
  createdAt     DateTime @default(now())

  @@unique([userId, day], name: "userId_day")
}
